# Backend
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Fireworks AI / AMD Hackathon
# Do not commit your real key. Put it only in .env
FIREWORKS_API_KEY=
FIREWORKS_API_BASE_URL=https://api.fireworks.ai/inference/v1

# Set exact model after checking your Fireworks dashboard/hackathon allocation.
# Example placeholder only:
FIREWORKS_MODEL=

# Narrative generation can run in fallback mode when no key is present.
ENABLE_LLM_NARRATIVE=false
